{
  "name": "trip-planner",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @trip-planner/api run db:generate",
    "db:migrate": "pnpm --filter @trip-planner/api run db:migrate",
    "db:seed": "pnpm --filter @trip-planner/api run db:seed",
    "api:dev": "pnpm --filter @trip-planner/api run dev",
    "web:dev": "pnpm --filter @trip-planner/web run dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.8.3",
    "@types/node": "^22.16.5",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.11"
  }
}
