{
  "name": "trip-planner",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "npm run db:generate -w @trip-planner/api",
    "db:migrate": "npm run db:migrate -w @trip-planner/api",
    "db:seed": "npm run db:seed -w @trip-planner/api",
    "api:dev": "npm run dev -w @trip-planner/api",
    "web:dev": "npm run dev -w @trip-planner/web"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.8.3",
    "@types/node": "^22.16.5",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.11"
  }
}
