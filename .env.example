# Copy to .env and fill in values for local dev.

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trip_planner
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trip_planner

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO / S3 ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=homepage-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/homepage-media
S3_FORCE_PATH_STYLE=true

# --- API server ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=
COOKIE_SECURE=false
# Set to false in production when running the BullMQ worker as a separate process.
ENABLE_EMBEDDED_WORKER=true

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-random-48-byte-secret
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# Initial admin (used by `npm run db:seed -w @trip-planner/api`)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# --- External APIs ---
OPENWEATHER_API_KEY=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@example.com
REMINDER_FALLBACK_EMAIL=fallback@example.com

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:3000
VITE_GOOGLE_MAPS_API_KEY=
